# =============================================================================
#  .env.example — Template de variables d'environnement
# -----------------------------------------------------------------------------
#  Comment l'utiliser :
#    1) Copier ce fichier en ".env" à la racine du projet :
#         (Linux/Mac)  cp .env.example .env
#         (Windows)    copy .env.example .env
#    2) Adapter les valeurs si besoin (ex: changer un port en cas de conflit).
#    3) Ce fichier ".env.example" EST versionné dans Git (sert de référence).
#       Le fichier ".env" N'EST PAS versionné (peut contenir des secrets).
# =============================================================================


# -----------------------------------------------------------------------------
#  PORTS HÔTES — utilisés par docker-compose.yml pour exposer les services
# -----------------------------------------------------------------------------
#  Si un port est déjà pris sur ta machine, change-le ici (ex: 8091 au lieu
#  de 8081). Aucun code n'a besoin d'être modifié.

MLFLOW_HOST_PORT=8081
API_HOST_PORT=8000
AIRFLOW_HOST_PORT=8082


# -----------------------------------------------------------------------------
#  MLFLOW_TRACKING_URI — où le code envoie les runs MLflow
# -----------------------------------------------------------------------------
#  Cette variable est LUE NATIVEMENT par MLflow (convention officielle).
#  Choisir la valeur en fonction d'OÙ s'exécute le code qui logge :
#
#    a) Code lancé sur ta machine (ex: `python src/models/train.py`) :
#         MLFLOW_TRACKING_URI=http://localhost:8081
#       → on passe par le port hôte mappé dans docker-compose.
#
#    b) Code lancé DANS UN CONTENEUR du même docker-compose (API, Airflow...) :
#         MLFLOW_TRACKING_URI=http://mlflow:8080
#       → on passe par le nom du service et le port INTERNE du conteneur.
#       Cette valeur est définie directement dans docker-compose.yml,
#       pas besoin de la mettre ici.

MLFLOW_TRACKING_URI=http://localhost:8081
